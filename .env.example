# ============================================================
# REVIEWPILOT — ENVIRONMENT VARIABLES
# Copy this to .env.local and fill in all values
# ============================================================

# ── SUPABASE ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── STRIPE ──────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create in Stripe dashboard)
STRIPE_STARTER_PRICE_ID=price_starter_monthly
STRIPE_PRO_PRICE_ID=price_pro_monthly
STRIPE_AGENCY_PRICE_ID=price_agency_monthly

# ── GOOGLE BUSINESS API ─────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=https://yourdomain.com/api/auth/google/callback

# ── AI ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── EMAIL (Resend) ──────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=ReviewPilot <hello@yourdomain.com>
EMAIL_REPLY_TO=support@yourdomain.com

# ── SMS (Twilio) ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ── AUTOMATION ──────────────────────────────────────────────
MAKE_ONBOARDING_WEBHOOK=https://hook.us1.make.com/your_webhook_id
MAKE_CHURN_WEBHOOK=https://hook.us1.make.com/your_churn_webhook_id
CRON_SECRET=generate_a_random_32_char_string_here

# ── APP ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_APP_NAME=ReviewPilot
ENCRYPTION_KEY=generate_a_random_32_char_string_here

# ── OPTIONAL: Lead Gen ───────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_maps_api_key
INSTANTLY_API_KEY=your_instantly_api_key
