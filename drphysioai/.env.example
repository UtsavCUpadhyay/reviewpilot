# ── DrPhysioAI environment ────────────────────────────────────────────────
# Copy to `.env.local` and fill in. Only NEXT_PUBLIC_* vars reach the browser.

# Shopify hosted checkout (see lib/shopify.ts).
# Storefront domain of the DrPhysioAI store — NOT PawHappiness/shrivyajewell.
NEXT_PUBLIC_SHOPIFY_DOMAIN=

# Map DrPhysioAI catalog keys -> Shopify *variant* ids (numbers), as JSON.
# Get the ids from the store (search_products / product admin). Example:
# NEXT_PUBLIC_SHOPIFY_VARIANTS={"plan:Ultimate Student":"12345678901","plan:Complete Care":"12345678902","service:Video Consultation":"12345678903"}
NEXT_PUBLIC_SHOPIFY_VARIANTS=
